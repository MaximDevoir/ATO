{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "types": ["node"],
    "paths": {
      "@ATO/UnrealLag": ["./packages/unreal-lag/src/index.ts"],
      "@ATO/ATO": ["./packages/ato/src/index.ts"]
    }
  }
}
