{
  "name": "uapkg",
  "version": "1.1.2",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "uapkg": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@amplication/csharp-ast": "0.1.0",
    "@types/yargs": "17.0.35",
    "@uapkg/common": "workspace:^",
    "@uapkg/common-schema": "workspace:^",
    "@uapkg/config": "workspace:^",
    "@uapkg/diagnostics": "workspace:^",
    "@uapkg/diagnostics-format": "workspace:^",
    "@uapkg/installer": "workspace:^",
    "@uapkg/log": "workspace:^",
    "@uapkg/pack": "workspace:^",
    "@uapkg/package-manifest": "workspace:^",
    "@uapkg/package-manifest-schema": "workspace:^",
    "@uapkg/registry-core": "workspace:^",
    "esbuild": "0.28.0",
    "ink": "6.8.0",
    "ink-select-input": "6.2.0",
    "ink-text-input": "6.0.0",
    "is-ci": "4.1.0",
    "react": "19.2.4",
    "yargs": "18.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/react": "19.2.14"
  },
  "scripts": {
    "uapkg": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "lint": "biome lint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MaximDevoir/ATO.git",
    "directory": "packages/uapkg"
  }
}
