{
  "name": "@maximdevoir/create-atc-harness",
  "version": "1.1.5",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "create-atc-harness": "./bin/create-atc-harness.cjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@maximdevoir/engine-association-resolver": "workspace:*",
    "@types/yargs": "17.0.35",
    "@uapkg/cli": "^1.1.9",
    "@uapkg/package-manifest": "^1.1.9",
    "dotenv": "17.4.1",
    "ink": "6.8.0",
    "ink-select-input": "6.2.0",
    "is-ci": "4.1.0",
    "react": "19.2.4",
    "simple-git": "3.35.1",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.14"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepack": "pnpm run build",
    "create-atc-harness": "node ./dist/cli.js",
    "create-atc-harness:dev": "tsx src/cli.ts",
    "lint": "biome lint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MaximDevoir/ATO.git",
    "directory": "packages/create-atc-harness"
  }
}
