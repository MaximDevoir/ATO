{
  "name": "@uapkg/pack",
  "version": "0.1.1",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@uapkg/diagnostics": "workspace:^",
    "@uapkg/log": "workspace:^",
    "ignore": "7.0.5",
    "semver": "7.7.4",
    "tar": "7.5.13",
    "zod": "4.3.6"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "lint": "biome lint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MaximDevoir/ATO.git",
    "directory": "packages/uapkg-pack"
  },
  "devDependencies": {
    "@types/semver": "7.7.1"
  }
}
