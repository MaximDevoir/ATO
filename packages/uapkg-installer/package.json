{
  "name": "@uapkg/installer",
  "version": "0.1.2",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@uapkg/common": "workspace:^",
    "@uapkg/common-schema": "workspace:^",
    "@uapkg/config": "workspace:^",
    "@uapkg/diagnostics": "workspace:^",
    "@uapkg/package-manifest": "workspace:^",
    "@uapkg/package-manifest-schema": "workspace:^",
    "@uapkg/registry-core": "workspace:^",
    "p-limit": "7.1.1",
    "tar": "7.5.13",
    "undici": "7.18.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "lint": "biome lint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MaximDevoir/ATO.git",
    "directory": "packages/uapkg-installer"
  }
}
