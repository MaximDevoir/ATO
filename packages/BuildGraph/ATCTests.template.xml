<?xml version="1.0"?>
<BuildGraph xmlns="http://www.epicgames.com/BuildGraph"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="{{SchemaLocation}}">

  <!-- ================= OPTIONS ================= -->

  <Option Name="ProjectFile" DefaultValue="{{ProjectFile}}" Description="Path to the Unreal Engine project file"/>
  <Option Name="ProjectDir" DefaultValue="{{ProjectDir}}"
          Description="Directory containing the Unreal Engine project"/>
  <Option Name="ProjectName" DefaultValue="{{ProjectName}}" Description="Name of the Unreal Engine project"/>
  <Option Name="EngineDir" DefaultValue="{{EngineDir}}"
          Description="Directory containing the Unreal Engine installation"/>

  <Option Name="ScriptsDir" DefaultValue="$(ProjectDir)/BuildGraph/Scripts"
          Description="Directory containing custom scripts for the build graph"/>
  <Option Name="CompilePlatform" DefaultValue="{{CompilePlatform}}"
          Description="Compile target platform (e.g. Win64, Linux, LinuxArm64, Mac)"/>
  <!-- Per-mode cook platforms: standalone/listen use non-server cooks, dedicated uses server cooks -->
  <Option Name="CookPlatformStandalone" DefaultValue="{{CookPlatformStandalone}}"
          Description="Cook platform for standalone/listen tests (e.g. Windows, Linux, Mac)"/>
  <Option Name="CookPlatformDedicated" DefaultValue="{{CookPlatformDedicated}}"
          Description="Cook platform for dedicated server tests (e.g. WindowsServer, LinuxServer, MacServer)"/>
  <!-- Listen uses the same cook platform as Standalone -->


  <!-- ================= GAME BUILD ================= -->
  <Agent Name="Default" Type="$(CompilePlatform)">

    <Node Name="CompileGame">
      <Compile Target="$(ProjectName)"
               Platform="$(CompilePlatform)"
               Configuration="Development"
               Project="$(ProjectFile)"/>
    </Node>

    <Node Name="CompileGameWithExceptions">
      <Compile Target="$(ProjectName)"
               Platform="$(CompilePlatform)"
               Configuration="Development"
               Project="$(ProjectFile)"
               Arguments="-Define=ATC_WITH_CPP_EXCEPTIONS=1"/>
    </Node>

    <Node Name="CookGame" Requires="CompileGame">
      <Cook Project="$(ProjectFile)"
            Platform="$(CookPlatformStandalone)"
            Maps="/Engine/Maps/Templates/OpenWorld+/Engine/Maps/Templates/Template_Default"
            Arguments="-iterate -unversioned"/>
    </Node>

    <Node Name="CookGameWithExceptions" Requires="CompileGameWithExceptions">
      <Cook Project="$(ProjectFile)"
            Platform="$(CookPlatformStandalone)"
            Maps="/Engine/Maps/Templates/OpenWorld+/Engine/Maps/Templates/Template_Default"
            Arguments="-iterate -unversioned"/>
    </Node>

    <!-- ================= SERVER BUILD ================= -->

    <Node Name="CompileServer">
      <Compile Target="$(ProjectName)Server"
               Platform="$(CompilePlatform)"
               Configuration="Development"
               Project="$(ProjectFile)"/>
    </Node>

    <Node Name="CookServer" Requires="CompileServer">
      <Cook Project="$(ProjectFile)"
            Platform="$(CookPlatformDedicated)"
            Maps="/Engine/Maps/Templates/OpenWorld+/Engine/Maps/Templates/Template_Default"
            Arguments="-iterate -unversioned"/>
    </Node>

    <!-- ================= EDITOR BUILD ================= -->

    <Node Name="CompileEditor">
      <Compile Target="$(ProjectName)Editor"
               Platform="$(CompilePlatform)"
               Configuration="Development"
               Project="$(ProjectFile)"/>
    </Node>

    <!-- ================= STANDALONE ================= -->

    <Node Name="RunStandaloneTest" Requires="CookGame">
      <Spawn Exe="node"
             WorkingDir="$(ProjectDir)"
             Arguments="--import tsx BuildGraph/Scripts/RunStandaloneTest.ts --UERoot &quot;$(EngineDir)&quot; --Project &quot;$(ProjectFile)&quot;"
             LogOutput="true"
             ErrorLevel="1"/>
    </Node>

    <!-- ================= STANDALONE WITH EXCEPTIONS ================= -->

    <Node Name="RunStandaloneTestWithExceptions" Requires="CookGameWithExceptions">
      <Spawn Exe="node"
             WorkingDir="$(ProjectDir)"
             Arguments="--import tsx BuildGraph/Scripts/RunStandaloneWithExceptionsTest.ts --UERoot &quot;$(EngineDir)&quot; --Project &quot;$(ProjectFile)&quot;"
             LogOutput="true"
             ErrorLevel="1"/>
    </Node>

    <!-- ================= DEDICATED ================= -->

    <Node Name="RunDedicatedTests" Requires="CookGame;CookServer">
      <Spawn Exe="node"
             WorkingDir="$(ProjectDir)"
             Arguments="--import tsx BuildGraph/Scripts/RunDedicated.tests.ts --UERoot &quot;$(EngineDir)&quot; --Project &quot;$(ProjectFile)&quot;"
             LogOutput="true"
             ErrorLevel="1"/>

    </Node>

    <!-- ================= LISTEN SERVER ================= -->

    <Node Name="RunListenTests" Requires="CookGame">
      <Spawn Exe="node"
             WorkingDir="$(ProjectDir)"
             Arguments="--import tsx BuildGraph/Scripts/RunListenServerTest.ts --UERoot &quot;$(EngineDir)&quot; --Project &quot;$(ProjectFile)&quot;"
             LogOutput="true"
             ErrorLevel="1"/>

    </Node>

    <!-- ================= PIE SERVER ================= -->
    <Node Name="RunPIETests" Requires="CompileEditor">
      <Spawn Exe="node"
             WorkingDir="$(ProjectDir)"
             Arguments="--import tsx BuildGraph/Scripts/RunPIETest.ts --UERoot &quot;$(EngineDir)&quot; --Project &quot;$(ProjectFile)&quot;"
             LogOutput="true"
             ErrorLevel="1"/>

    </Node>
  </Agent>

  <!-- ================= ALL TESTS ================= -->
  <!-- ================= AGGREGATES ================= -->

  <Aggregate Name="StandaloneWithExceptions" Requires="RunStandaloneTestWithExceptions"/>
  <Aggregate Name="Standalone" Requires="RunStandaloneTest"/>
  <Aggregate Name="Dedicated" Requires="RunDedicatedTests"/>
  <Aggregate Name="Listen" Requires="RunListenTests"/>
  <Aggregate Name="PIE" Requires="RunPIETests"/>

  <Aggregate Name="ATCTests"
             Requires="RunStandaloneTestWithExceptions;RunStandaloneTest;RunDedicatedTests;RunListenTests;RunPIETests"/>
</BuildGraph>
